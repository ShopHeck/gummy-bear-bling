<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  {% include 'shop-sheriff-amp' %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

  {%- comment -%} Social sharing (Open Graph + Twitter) — drives CTR from social/SEO {%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if page_description -%}<meta property="og:description" content="{{ page_description | escape }}">{%- endif -%}
  {%- assign og_image = page_image | default: product.featured_media | default: settings.favicon -%}
  {%- if og_image != blank -%}
    <meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">
    <meta name="twitter:card" content="summary_large_image">
  {%- else -%}
    <meta name="twitter:card" content="summary">
  {%- endif -%}
  <meta name="theme-color" content="#DC1A57">

  {%- comment -%} Structured data for rich results {%- endcomment -%}
  {%- if request.page_type == 'product' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 300 | json }},
      {% if product.featured_media %}"image": "https:{{ product.featured_media | image_url: width: 1200 }}",{% endif %}
      "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
      "offers": {
        "@type": "Offer",
        "url": "{{ shop.url }}{{ product.url }}",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": "{{ product.price | divided_by: 100.0 }}",
        "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
      }
    }
    </script>
  {%- elsif request.page_type == 'index' -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": "{{ shop.url }}",
      {%- capture social_list -%}
        {%- if settings.social_instagram != blank %}{{ settings.social_instagram | json }}|{% endif -%}
        {%- if settings.social_tiktok != blank %}{{ settings.social_tiktok | json }}|{% endif -%}
        {%- if settings.social_pinterest != blank %}{{ settings.social_pinterest | json }}|{% endif -%}
        {%- if settings.social_facebook != blank %}{{ settings.social_facebook | json }}{% endif -%}
      {%- endcapture -%}
      "sameAs": [{{ social_list | split: '|' | join: ',' }}]
    }
    </script>
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- if settings.heading_color != blank -%}
  <style>
    :root{ --ink: {{ settings.heading_color }}; --cta: {{ settings.accent_color }}; }
  </style>
  {%- endif -%}

  {{ content_for_header }}
</head>

<body class="template-{{ request.page_type }}">

  {%- comment -%} Reusable gummy-bear silhouette, referenced by SVG <use> everywhere {%- endcomment -%}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <symbol id="gbear" viewBox="0 0 100 110">
      <circle cx="30" cy="20" r="11"/><circle cx="70" cy="20" r="11"/>
      <circle cx="50" cy="30" r="20"/>
      <ellipse cx="50" cy="72" rx="27" ry="30"/>
      <ellipse cx="20" cy="62" rx="11" ry="15"/><ellipse cx="80" cy="62" rx="11" ry="15"/>
      <ellipse cx="33" cy="100" rx="12" ry="11"/><ellipse cx="67" cy="100" rx="12" ry="11"/>
    </symbol>
  </svg>

  <a class="visually-hidden" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- if request.page_type == 'product' -%}
    <div class="sticky-buy">
      <div class="pinfo">{{ product.title | truncatewords: 4 }}<small>{{ product.price | money }} · free US shipping</small></div>
      <a href="#pdp-add" class="btn" style="padding:.8rem 1.4rem">Add to cart</a>
    </div>
  {%- endif -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
