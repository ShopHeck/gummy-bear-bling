<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  {% include 'shop-sheriff-amp' %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- if settings.heading_color != blank -%}
  <style>
    :root{ --ink: {{ settings.heading_color }}; --cta: {{ settings.accent_color }}; }
  </style>
  {%- endif -%}

  {{ content_for_header }}
</head>

<body class="template-{{ request.page_type }}">

  {%- comment -%} Reusable gummy-bear silhouette, referenced by SVG <use> everywhere {%- endcomment -%}
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <symbol id="gbear" viewBox="0 0 100 110">
      <circle cx="30" cy="20" r="11"/><circle cx="70" cy="20" r="11"/>
      <circle cx="50" cy="30" r="20"/>
      <ellipse cx="50" cy="72" rx="27" ry="30"/>
      <ellipse cx="20" cy="62" rx="11" ry="15"/><ellipse cx="80" cy="62" rx="11" ry="15"/>
      <ellipse cx="33" cy="100" rx="12" ry="11"/><ellipse cx="67" cy="100" rx="12" ry="11"/>
    </symbol>
  </svg>

  <a class="visually-hidden" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {%- if request.page_type == 'product' -%}
    <div class="sticky-buy">
      <div class="pinfo">{{ product.title | truncatewords: 4 }}<small>{{ product.price | money }} · free US shipping</small></div>
      <a href="#pdp-add" class="btn" style="padding:.8rem 1.4rem">Add to cart</a>
    </div>
  {%- endif -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
