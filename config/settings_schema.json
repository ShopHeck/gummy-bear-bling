    "settings": [
      { "type": "image_picker", "id": "favicon", "label": "Favicon" }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "accent_color", "label": "Accent / button color", "default": "#DC1A57" },
      { "type": "color", "id": "heading_color", "label": "Text color", "default": "#34202C" }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "checkbox", "id": "enable_cart_drawer", "label": "Enable slide-out cart drawer", "default": true },
      { "type": "checkbox", "id": "enable_ajax_add", "label": "Add to cart without page reload", "default": true },
      { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping / reward threshold ($)", "info": "Shows a progress bar in the cart. Set 0 to show a simple 'free shipping' message instead.", "default": 0 },
      { "type": "text", "id": "cart_promo_text", "label": "Cart promo text", "default": "✨ Build a 3-bear stack & save $15" },
      { "type": "url", "id": "cart_promo_link", "label": "Cart promo link" }
    ]
  },
  {
    "name": "Reviews & rating",
    "settings": [
      { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": true },
      { "type": "text", "id": "rating_value", "label": "Average rating (0–5)", "default": "4.9" },
      { "type": "text", "id": "rating_count", "label": "Number of reviews", "default": "2,000+" }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "url", "id": "social_tiktok", "label": "TikTok URL" },
      { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "url", "id": "social_pinterest", "label": "Pinterest URL" },
      { "type": "url", "id": "social_facebook", "label": "Facebook URL" }
    ]
  },
  {
    "name": "Email popup",
    "settings": [
      { "type": "checkbox", "id": "enable_email_popup", "label": "Enable email signup popup", "default": true },
      { "type": "text", "id": "popup_incentive", "label": "Incentive badge", "default": "🍬 10% off your first bear" },
      { "type": "text", "id": "popup_heading", "label": "Heading", "default": "Join the gummy bear gang" },
      { "type": "textarea", "id": "popup_text", "label": "Text", "default": "First dibs on new flavors, drops, and 10% off your first order." },
      { "type": "text", "id": "popup_button", "label": "Button", "default": "Send my 10% off" },
      { "type": "number", "id": "popup_delay", "label": "Show after (seconds)", "default": 6 }
    ]
