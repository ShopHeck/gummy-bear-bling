{%- liquid
  assign s = section.settings
-%}
<div class="section">
  <div class="wrap cc-wrap">
    {%- if s.heading != blank -%}<div class="cc-head"><h2>{{ s.heading }}</h2></div>{%- endif -%}
    <div class="cc">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <details class="cc__item"{% if forloop.first and s.open_first %} open{% endif %} {{ block.shopify_attributes }}>
          <summary class="cc__q">{{ b.question | default: 'Question' }}<span class="cc__icon" aria-hidden="true">+</span></summary>
          <div class="cc__a rte">{{ b.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>
<style>
  .cc-wrap{max-width:780px}
  .cc-head{text-align:center;margin-bottom:24px}
  .cc-head h2{font-family:var(--font-display,sans-serif);font-size:clamp(1.7rem,3.6vw,2.5rem);margin:0}
  .cc__item{border:1px solid var(--line,rgba(0,0,0,.08));border-radius:var(--r-md,16px);margin-bottom:12px;background:#fff;overflow:hidden}
  .cc__q{display:flex;justify-content:space-between;align-items:center;gap:16px;cursor:pointer;list-style:none;padding:18px 20px;font-family:var(--font-display,sans-serif);font-weight:700;font-size:1.06rem}
  .cc__q::-webkit-details-marker{display:none}
  .cc__icon{flex:none;font-size:1.5rem;line-height:1;transition:transform .2s;color:var(--cta,#DC1A57)}
  .cc__item[open] .cc__icon{transform:rotate(45deg)}
  .cc__a{padding:0 20px 18px;color:var(--ink-soft,#7C6070)}
  .cc__a > *:first-child{margin-top:0}
</style>
{% schema %}
{
  "name": "FAQ / Collapsible",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "checkbox", "id": "open_first", "label": "Open first item by default", "default": false }
  ],
  "blocks": [
    { "type": "qa", "name": "Question", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add your answer here.</p>" }
    ] }
  ],
  "presets": [{ "name": "FAQ / Collapsible", "blocks": [ { "type": "qa" }, { "type": "qa" }, { "type": "qa" } ] }]
}
{% endschema %}
