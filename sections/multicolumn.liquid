{%- liquid
  assign s = section.settings
-%}
<div class="section">
  <div class="wrap">
    {%- if s.heading != blank or s.subheading != blank or s.eyebrow != blank -%}
      <div class="mc-head">
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
        {%- if s.subheading != blank -%}<p class="muted">{{ s.subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="mc mc--{{ s.columns }}">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <div class="mc__col" {{ block.shopify_attributes }}>
          {%- if b.image != blank -%}
            <img class="mc__img" src="{{ b.image | image_url: width: 600 }}" alt="{{ b.image.alt | escape | default: b.title | escape }}" loading="lazy" width="300" height="300">
          {%- elsif b.icon != blank -%}
            <div class="mc__icon">{{ b.icon }}</div>
          {%- endif -%}
          {%- if b.title != blank -%}<h3 class="mc__title">{{ b.title }}</h3>{%- endif -%}
          {%- if b.text != blank -%}<p class="mc__text">{{ b.text }}</p>{%- endif -%}
          {%- if b.link_label != blank -%}<a class="mc__link" href="{{ b.link_url | default: '#' }}">{{ b.link_label }} &rarr;</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
<style>
  .mc-head{text-align:center;max-width:640px;margin:0 auto 28px}
  .mc-head h2{font-family:var(--font-display,sans-serif);font-size:clamp(1.7rem,3.6vw,2.5rem);margin:.2rem 0 .4rem}
  .mc{display:grid;gap:clamp(14px,2vw,24px)}
  .mc--2{grid-template-columns:repeat(2,1fr)}.mc--3{grid-template-columns:repeat(3,1fr)}.mc--4{grid-template-columns:repeat(4,1fr)}
  .mc__col{background:rgba(255,255,255,.6);border:1px solid var(--line,rgba(0,0,0,.06));border-radius:var(--r-md,20px);padding:24px;text-align:center}
  .mc__img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:14px;margin-bottom:14px}
  .mc__icon{font-size:2.2rem;margin-bottom:10px}
  .mc__title{font-family:var(--font-display,sans-serif);font-size:1.18rem;margin:0 0 .35rem}
  .mc__text{color:var(--ink-soft,#7C6070);font-size:.95rem;margin:0 0 .5rem}
  .mc__link{font-weight:700;color:var(--cta,#DC1A57)}
  @media(max-width:900px){ .mc--3,.mc--4{grid-template-columns:repeat(2,1fr)} }
  @media(max-width:520px){ .mc--2,.mc--3,.mc--4{grid-template-columns:1fr} }
</style>
{% schema %}
{
  "name": "Multicolumn",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Gummy Bear Bling" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "select", "id": "columns", "label": "Columns", "default": "3", "options": [
      { "value": "2", "label": "2" }, { "value": "3", "label": "3" }, { "value": "4", "label": "4" } ] }
  ],
  "blocks": [
    { "type": "column", "name": "Column", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image (optional)" },
      { "type": "text", "id": "icon", "label": "Emoji icon (used if no image)", "default": "🐻" },
      { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "A short benefit or description." },
      { "type": "text", "id": "link_label", "label": "Link label" },
      { "type": "url", "id": "link_url", "label": "Link URL" }
    ] }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Multicolumn", "blocks": [ { "type": "column" }, { "type": "column" }, { "type": "column" } ] }]
}
{% endschema %}
