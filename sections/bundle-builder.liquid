{%- comment -%}
  Build-a-stack bundle. Uses the page's product on the bundle product template,
  or a product chosen in the section settings when placed on any other page.
  The form is guarded so the section never errors without a product.
{%- endcomment -%}
{%- assign bb_product = section.settings.product | default: product -%}
<div class="section">
  <div class="wrap">
    <div class="pdp bundle-builder" data-stack>
      <div class="pdp-media">
        <div class="pdp-main-img gummy">
          <div class="bb-stage" data-stack-slots>
            {%- for i in (1..3) -%}
              <div class="slot" data-stack-slot>
                <span class="ph-num">{{ i }}</span>
                <span class="bearbox" data-bear data-filled="1"></span>
                <span class="slot-x" aria-hidden="true">×</span>
              </div>
            {%- endfor -%}
          </div>
        </div>
        <p class="center muted" style="font-size:.85rem;font-weight:600;margin-top:.8rem">Tap a slot to clear it</p>
      </div>

      <div class="pdp-info">
        <span class="eyebrow">{{ bb_product.type | default: 'Build your own stack' }}</span>
        <h1>{{ bb_product.title | default: section.settings.heading | default: 'Build Your Own Stack' }}</h1>
        <div class="pdp-rev"><span class="stars">★★★★★</span> Loved by the gummy bear gang</div>

        {%- if bb_product != blank -%}
          <div class="pdp-price">
            {{ bb_product.price | money }}
            {%- if bb_product.compare_at_price > bb_product.price -%}
              <s>{{ bb_product.compare_at_price | money }}</s>
              <span class="save">Save {{ bb_product.compare_at_price | minus: bb_product.price | money }}</span>
            {%- endif -%}
          </div>
        {%- elsif section.settings.price != blank -%}
          <div class="pdp-price"><span class="now">{{ section.settings.price }}</span></div>
        {%- endif -%}

        {%- if bb_product.description != blank -%}
          <div class="pdp-desc rte" style="margin-top:1rem">{{ bb_product.description }}</div>
        {%- endif -%}

        <h3 class="bb-step" style="font-family:var(--font-display);margin:1.4rem 0 .6rem">1 · Pick a flavor for each bear</h3>
        <div class="pickrow" data-stack-picker>
          {%- if section.settings.flavor_source != blank -%}
            {% render 'flavor-from-variants', product: section.settings.flavor_source, mode: 'stack' %}
          {%- else -%}
            {%- for block in section.blocks -%}
              <button type="button" class="swatch" data-stack-flavor
                style="background:{{ block.settings.color }}"
                data-color="{{ block.settings.color }}"
                data-label="{{ block.settings.label | escape }}"
                aria-label="Add {{ block.settings.label | escape }} to your stack"
                {{ block.shopify_attributes }}></button>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <p class="bundle-hint muted" data-stack-hint style="margin-top:.7rem">Pick 3 flavors to fill your stack.</p>

        {%- if bb_product != blank -%}
          {%- form 'product', bb_product, id: 'bundle-add' -%}
            <input type="hidden" name="id" value="{{ bb_product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="properties[Bear 1]" data-stack-prop>
            <input type="hidden" name="properties[Bear 2]" data-stack-prop>
            <input type="hidden" name="properties[Bear 3]" data-stack-prop>
            <div class="pdp-actions" style="margin-top:1.2rem">
              <button type="submit" name="add" class="btn lg full" data-stack-submit disabled {% unless bb_product.available %}disabled{% endunless %}>
                {%- if bb_product.available -%}Add stack to cart{%- else -%}Sold out{%- endif -%}
              </button>
            </div>
          {%- endform -%}
        {%- else -%}
          <div class="pdp-actions" style="margin-top:1.2rem">
            <a class="btn lg full" href="{{ routes.all_products_collection_url }}">Shop the bears</a>
          </div>
          <p class="muted" style="font-size:.82rem;margin-top:.6rem">Tip: set this section's <b>Bundle product</b> in the theme editor to enable add-to-cart here.</p>
        {%- endif -%}

        <div class="pdp-trust">
          <div><span class="ic">🇺🇸</span><div><b>Handmade in the USA</b><small>Hand-poured in Tampa, FL</small></div></div>
          <div><span class="ic">🚚</span><div><b>Free US shipping</b><small>Fast same-day dispatch</small></div></div>
          <div><span class="ic">↩︎</span><div><b>30-day returns</b><small>Love it or send it back</small></div></div>
          <div><span class="ic">🔒</span><div><b>Secure checkout</b><small>Shop Pay, Apple Pay &amp; cards</small></div></div>
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Build-a-stack bundle",
  "settings": [
    { "type": "product", "id": "product", "label": "Bundle product", "info": "The fixed-price 3-bear bundle product. Leave blank on the bundle product's own page (it uses that product automatically); set it when adding this section to any other page so add-to-cart works." },
    { "type": "product", "id": "flavor_source", "label": "Flavor source (necklace)", "info": "Optional: pick a necklace with colour variants to show its real product photos in the picker and slots. Leave blank to use the manual flavor blocks below." },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Build Your Own Stack" },
    { "type": "text", "id": "price", "label": "Fallback price", "default": "$45" }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Flavor",
      "settings": [
        { "type": "color", "id": "color", "label": "Bear color", "default": "#FF3B5C" },
        { "type": "text", "id": "label", "label": "Flavor name", "default": "Cherry" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Build-a-stack bundle",
    "blocks": [
      { "type": "flavor", "settings": { "color": "#FF3B5C", "label": "Cherry" } },
      { "type": "flavor", "settings": { "color": "#FF8A3D", "label": "Tangerine" } },
      { "type": "flavor", "settings": { "color": "#FFCE2E", "label": "Lemon" } },
      { "type": "flavor", "settings": { "color": "#46CF7C", "label": "Lime" } },
      { "type": "flavor", "settings": { "color": "#3D8BFF", "label": "Blueberry" } },
      { "type": "flavor", "settings": { "color": "#A55CFF", "label": "Grape" } },
      { "type": "flavor", "settings": { "color": "#FF6FB0", "label": "Bubblegum" } },
      { "type": "flavor", "settings": { "color": "#34D6D6", "label": "Aqua" } }
    ]
  }]
}
{% endschema %}
