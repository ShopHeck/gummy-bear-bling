{%- liquid
  assign s = section.settings
-%}
<div class="section">
  <div class="wrap">
    <div class="iwt iwt--{{ s.image_position }}{% if s.bg != blank %} iwt--card{% endif %}"{% if s.bg != blank %} style="background:{{ s.bg }}"{% endif %}>
      <div class="iwt__media">
        {%- if s.image != blank -%}
          <img src="{{ s.image | image_url: width: 1200 }}"
               srcset="{{ s.image | image_url: width: 600 }} 600w, {{ s.image | image_url: width: 1200 }} 1200w"
               sizes="(max-width:760px) 100vw, 50vw"
               alt="{{ s.image.alt | escape | default: s.heading | escape }}" loading="lazy" width="1000" height="1000">
        {%- else -%}
          <div class="iwt__placeholder"></div>
        {%- endif -%}
      </div>
      <div class="iwt__body">
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
        {%- if s.text != blank -%}<div class="iwt__text rte">{{ s.text }}</div>{%- endif -%}
        {%- if s.button_label != blank -%}<a class="btn lg" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</div>
<style>
  .iwt{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:clamp(20px,4vw,52px)}
  .iwt--card{border-radius:var(--r-lg,28px);padding:clamp(20px,3vw,40px)}
  .iwt--right .iwt__media{order:2}
  .iwt__media img,.iwt__placeholder{width:100%;border-radius:var(--r-md,20px);aspect-ratio:1/1;object-fit:cover;display:block}
  .iwt__placeholder{background:linear-gradient(120deg,#FF6FB0,#34D6D6)}
  .iwt__body h2{font-family:var(--font-display,sans-serif);font-size:clamp(1.6rem,3.4vw,2.4rem);line-height:1.05;margin:.2rem 0 .6rem}
  .iwt__text{color:var(--ink-soft,#7C6070);margin-bottom:1.1rem}
  @media(max-width:760px){ .iwt{grid-template-columns:1fr} .iwt--right .iwt__media{order:0} }
</style>
{% schema %}
{
  "name": "Image with text",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [
      { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ] },
    { "type": "color", "id": "bg", "label": "Card background (optional)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why you'll love it" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Handmade, glossy, built to last" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this space to tell your brand story or explain a product detail.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
