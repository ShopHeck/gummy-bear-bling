{%- liquid
  assign s = section.settings
  assign show_hero = false
  if s.show_hero_image and collection.image != blank
    assign show_hero = true
  endif
  # find a colour/flavour filter (when Search & Discovery exposes one)
  assign color_filter = nil
  for f in collection.filters
    assign fl = f.label | downcase
    if fl contains 'color' or fl contains 'colour' or fl contains 'flavor' or fl contains 'flavour'
      if color_filter == nil
        assign color_filter = f
      endif
    endif
  endfor
-%}
{%- if show_hero -%}
  <section class="coll-hero">
    <img class="coll-hero-img" src="{{ collection.image | image_url: width: 2000 }}"
         srcset="{{ collection.image | image_url: width: 800 }} 800w, {{ collection.image | image_url: width: 1400 }} 1400w, {{ collection.image | image_url: width: 2000 }} 2000w"
         sizes="100vw" alt="{{ collection.title | escape }}" width="2000" height="700" fetchpriority="high">
    <span class="coll-hero-scrim"></span>
    <div class="coll-hero-inner wrap">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<div class="rte coll-hero-desc">{{ collection.description }}</div>{%- endif -%}
    </div>
  </section>
{%- else -%}
  <div class="coll-head">
    <div class="wrap">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<div class="rte muted" style="margin-top:.6rem">{{ collection.description }}</div>{%- endif -%}
    </div>
  </div>
{%- endif -%}

<div class="section" style="padding-top:18px">
  <div class="wrap">
    <div class="coll-subhead">
      {%- if settings.show_rating -%}
        <div class="coll-meta"><span class="stars">★★★★★</span> {{ settings.rating_value }} · loved by {{ settings.rating_count }} customers</div>
      {%- endif -%}
      <div class="coll-trust">
        <span>🇺🇸 Handmade in the USA</span>
        <span>🚚 Free US shipping</span>
        <span>↩︎ 30-day returns</span>
        <span>🔒 Secure checkout</span>
      </div>
      {%- if s.show_flavor_row and color_filter != nil -%}
        <div class="coll-flavors">
          <span class="coll-flavors-lbl">Shop by color:</span>
          {%- for v in color_filter.values -%}
            {%- capture chex -%}{% render 'color-hex', name: v.label %}{%- endcapture -%}
            <a class="coll-flavor{% if v.active %} active{% endif %}"
               href="{% if v.active %}{{ v.url_to_remove }}{% else %}{{ v.url_to_add }}{% endif %}"
               style="background:{{ chex | strip | default: '#ddd' }}"
               title="{{ v.label }} ({{ v.count }})" aria-label="Filter by {{ v.label | escape }}"></a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <form method="get" class="coll-filterbar">
      <div class="cf-row">
        {%- for filter in collection.filters -%}
          <details class="cf-drop">
            <summary>{{ filter.label }}{%- if filter.type == 'price_range' -%}{%- if filter.min_value.value or filter.max_value.value %} •{% endif -%}{%- elsif filter.active_values.size > 0 %} ({{ filter.active_values.size }}){% endif -%}</summary>
            <div class="cf-panel">
              {%- case filter.type -%}
              {%- when 'list', 'boolean' -%}
                {%- for v in filter.values -%}
                  <label class="cf-opt"><input type="checkbox" name="{{ v.param_name }}" value="{{ v.value | escape }}"{% if v.active %} checked{% endif %}><span>{{ v.label }}</span><small>{{ v.count }}</small></label>
                {%- endfor -%}
                <button type="submit" class="btn sm cf-apply">Apply</button>
              {%- when 'price_range' -%}
                <div class="cf-price">
                  <input type="number" inputmode="decimal" min="0" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}" placeholder="Min">
                  <span>–</span>
                  <input type="number" inputmode="decimal" min="0" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}" placeholder="Max">
                  <button type="submit" class="btn sm">Go</button>
                </div>
              {%- endcase -%}
            </div>
          </details>
        {%- endfor -%}
        <span class="cf-spacer"></span>
        <span class="cf-count">{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</span>
        {%- if collection.sort_options.size > 0 -%}
          <label class="cf-sort">Sort
            <select name="sort_by" onchange="this.form.submit()">
              {%- assign current_sort = collection.sort_by | default: collection.default_sort_by -%}
              {%- for opt in collection.sort_options -%}
                <option value="{{ opt.value }}"{% if opt.value == current_sort %} selected{% endif %}>{{ opt.name }}</option>
              {%- endfor -%}
            </select>
          </label>
        {%- endif -%}
        <noscript><button type="submit" class="btn sm">Apply</button></noscript>
      </div>
      {%- assign any_active = false -%}
      {%- for filter in collection.filters -%}
        {%- if filter.active_values.size > 0 or filter.min_value.value or filter.max_value.value -%}{%- assign any_active = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if any_active -%}
        <div class="cf-active">
          {%- for filter in collection.filters -%}
            {%- for v in filter.active_values -%}
              <a class="cf-chip" href="{{ v.url_to_remove }}">{{ v.label }} ✕</a>
            {%- endfor -%}
            {%- if filter.type == 'price_range' and filter.min_value.value or filter.max_value.value -%}
              <a class="cf-chip" href="{{ filter.url_to_remove }}">{{ filter.label }} ✕</a>
            {%- endif -%}
          {%- endfor -%}
          <a class="cf-clear" href="{{ collection.url }}">Clear all</a>
        </div>
      {%- endif -%}
    </form>

    {%- paginate collection.products by 12 -%}
      <div class="grid">
        {%- assign colors = '#3D8BFF,#FF3B5C,#A55CFF,#FF8A3D,#46CF7C,#FF6FB0,#FFCE2E,#34D6D6' | split: ',' -%}
        {%- assign promo_pos = s.promo_position | default: 4 -%}
        {%- for product in collection.products -%}
          {%- if s.show_promo_tile and forloop.index == promo_pos -%}
            <a class="promo-tile gummy" href="{{ s.promo_link | default: routes.all_products_collection_url }}">
              <span class="promo-tile-badge">Limited time</span>
              <h3>{{ s.promo_title | default: '🎆 20% off everything' }}</h3>
              {%- if s.promo_text != blank -%}<p>{{ s.promo_text }}</p>{%- endif -%}
              <span class="promo-tile-cta">{{ s.promo_cta | default: 'Shop the sale' }} →</span>
            </a>
          {%- endif -%}
          {% render 'product-card', product: product, bear_color: colors[forloop.index0] %}
        {%- else -%}
          <p class="muted" style="grid-column:1/-1;text-align:center;padding:30px 0">No products match these filters. <a href="{{ collection.url }}">Clear filters</a> to see everything.</p>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="pagination">{{ paginate | default_pagination }}</nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>
{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "header", "content": "Hero banner" },
    { "type": "checkbox", "id": "show_hero_image", "label": "Use collection image as a hero banner", "default": true },
    { "type": "header", "content": "Shop by color" },
    { "type": "checkbox", "id": "show_flavor_row", "label": "Show 'shop by color' swatches", "info": "Appears when Search & Discovery exposes a Color/Flavor filter on this collection.", "default": true },
    { "type": "header", "content": "In-grid promo tile" },
    { "type": "checkbox", "id": "show_promo_tile", "label": "Show promo tile in the grid", "default": true },
    { "type": "text", "id": "promo_title", "label": "Promo title", "default": "🎆 20% off everything" },
    { "type": "text", "id": "promo_text", "label": "Promo text", "default": "Use code USA20 at checkout — ends July 4." },
    { "type": "text", "id": "promo_cta", "label": "Promo button", "default": "Shop the sale" },
    { "type": "url", "id": "promo_link", "label": "Promo link" },
    { "type": "range", "id": "promo_position", "label": "Promo tile position in grid", "min": 1, "max": 12, "step": 1, "default": 4 }
  ]
}
{% endschema %}
