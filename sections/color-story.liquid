<div class="section">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="colorstory gummy reveal" data-colorstory>
      <div class="stage"><span class="bearbox" data-colorstory-stage style="width:min(280px,72%)"></span></div>
      <div>
        <div class="flavors" data-colorstory-row>
          {%- assign fallback = section.settings.cta_link | default: routes.all_products_collection_url -%}
          {%- for block in section.blocks -%}
            {%- assign fp = block.settings.product -%}
            {%- if fp != blank -%}{%- assign furl = fp.url -%}{%- else -%}{%- assign furl = fallback -%}{%- endif -%}
            <a class="swatch{% if forloop.first %} active{% endif %}"
               href="{{ furl }}"
               style="background:{{ block.settings.color }}"
               data-flavor
               data-color="{{ block.settings.color }}"
               data-label="{{ block.settings.label | escape }}"
               data-desc="{{ block.settings.description | escape }}"
               data-url="{{ furl }}"
               aria-label="{{ block.settings.label | escape }} — shop this necklace"
               {{ block.shopify_attributes }}></a>
          {%- endfor -%}
        </div>
        <p class="flavor-name" data-colorstory-name></p>
        <a href="{{ fallback }}" class="btn" data-colorstory-cta data-label="{{ section.settings.cta_text }}" style="margin-top:.4rem">{{ section.settings.cta_text }}</a>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Color story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tap a flavor" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Which one's yours?" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Tap a flavor to meet the bear — then shop that exact necklace." },
    { "type": "text", "id": "cta_text", "label": "Button text", "info": "Use %s as a placeholder for the flavor name, e.g. \"Shop the %s bear\".", "default": "Shop the %s bear" },
    { "type": "url", "id": "cta_link", "label": "Fallback link", "info": "Used when a flavor has no product assigned." }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Flavor",
      "settings": [
        { "type": "color", "id": "color", "label": "Bear color", "default": "#3D8BFF" },
        { "type": "text", "id": "label", "label": "Flavor name", "default": "Blueberry" },
        { "type": "text", "id": "description", "label": "Short description", "default": "cool, classic, goes with everything." },
        { "type": "product", "id": "product", "label": "Matched necklace", "info": "The individual necklace this color links to." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Color story",
    "blocks": [
      { "type": "flavor", "settings": { "color": "#3D8BFF", "label": "Blueberry", "description": "cool, classic, goes with everything." } },
      { "type": "flavor", "settings": { "color": "#FF3B5C", "label": "Cherry", "description": "bold and sweet — our most-gifted bear." } },
      { "type": "flavor", "settings": { "color": "#A55CFF", "label": "Grape", "description": "dreamy purple, a festival favorite." } },
      { "type": "flavor", "settings": { "color": "#FF6FB0", "label": "Bubblegum", "description": "soft pink Y2K nostalgia in a bear." } },
      { "type": "flavor", "settings": { "color": "#FF8A3D", "label": "Tangerine", "description": "sunny orange that pops on gold." } },
      { "type": "flavor", "settings": { "color": "#FFCE2E", "label": "Lemon", "description": "bright, cheerful, impossible to miss." } },
      { "type": "flavor", "settings": { "color": "#46CF7C", "label": "Lime", "description": "fresh green, a little bit retro." } },
      { "type": "flavor", "settings": { "color": "#34D6D6", "label": "Aqua", "description": "breezy teal for summer stacks." } }
    ]
  }]
}
{% endschema %}
