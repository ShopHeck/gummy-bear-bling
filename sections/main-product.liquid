<div class="section">
  <div class="wrap">
    <div class="pdp">
      <div class="pdp-media">
        <div class="pdp-main-img gummy" data-pdp-main>
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | image_url: width: 900 }}"
                 srcset="{{ product.featured_media | image_url: width: 400 }} 400w,
                         {{ product.featured_media | image_url: width: 600 }} 600w,
                         {{ product.featured_media | image_url: width: 900 }} 900w,
                         {{ product.featured_media | image_url: width: 1200 }} 1200w"
                 sizes="(max-width:900px) 100vw, 50vw"
                 alt="{{ product.featured_media.alt | escape | default: product.title }}"
                 width="900" height="900" fetchpriority="high">
          {%- else -%}
            <span class="bearbox" data-bear="#3D8BFF"></span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="pdp-thumbs" data-pdp-thumbs>
            {%- for media in product.media limit: 8 -%}
              <button class="{% if forloop.first %}active{% endif %}" data-src="{{ media | image_url: width: 900 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ media | image_url: width: 140 }}" alt="" loading="lazy" width="66" height="66">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="pdp-info">
        <span class="eyebrow">{{ product.type | default: 'Gummy bear jewelry' }}</span>
        <h1>{{ product.title }}</h1>

        {%- if settings.show_rating -%}
          {%- if product.metafields.reviews.rating.value != blank -%}
            <a href="#reviews" class="pdp-rev"><span class="stars">★★★★★</span> {{ product.metafields.reviews.rating.value }} · {{ product.metafields.reviews.rating_count }} reviews</a>
          {%- else -%}
            <a href="#reviews" class="pdp-rev"><span class="stars">★★★★★</span> {{ settings.rating_value }} · loved by {{ settings.rating_count }} customers</a>
          {%- endif -%}
        {%- endif -%}

        <div class="pdp-price">
          {{ product.price | money }}
          {%- if product.compare_at_price > product.price -%}
            <s>{{ product.compare_at_price | money }}</s>
            <span class="save">Save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- endif -%}
        </div>

        {%- assign cv = product.selected_or_first_available_variant -%}
        {%- if section.settings.pdp_show_scarcity -%}
          {%- assign show_stock = false -%}
          {%- if cv.inventory_management != blank and cv.inventory_quantity > 0 and cv.inventory_quantity <= section.settings.pdp_scarcity_threshold -%}{%- assign show_stock = true -%}{%- endif -%}
          <p class="pdp-stock" data-stock{% unless show_stock %} hidden{% endunless %}>🔥 Only <strong data-stock-n>{{ cv.inventory_quantity }}</strong> left — selling fast!</p>
        {%- endif -%}

        {%- form 'product', product, id: 'pdp-add', class: 'pdp-form' -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              {%- assign optidx = forloop.index -%}
              {%- assign oname = option.name | downcase -%}
              {%- assign is_color = false -%}
              {%- if oname contains 'color' or oname contains 'colour' or oname contains 'flavor' or oname contains 'flavour' -%}{%- assign is_color = true -%}{%- endif -%}
              <div class="opt">
                <label class="opt-label" {% unless is_color %}for="opt-{{ optidx }}"{% endunless %}>
                  {{ option.name }}{%- if is_color -%}: <span class="opt-current" data-opt-current="option{{ optidx }}">{{ option.selected_value }}</span>{%- endif -%}
                </label>
                {%- if is_color -%}
                  <div class="opt-swatches" role="radiogroup" aria-label="{{ option.name | escape }}">
                    {%- for value in option.values -%}
                      {%- capture hex -%}{% render 'color-hex', name: value %}{%- endcapture -%}
                      {%- assign selected = false -%}
                      {%- if option.selected_value == value -%}{%- assign selected = true -%}{%- endif -%}
                      <button type="button"
                        class="opt-swatch{% if selected %} active{% endif %}"
                        style="background:{{ hex | strip }}"
                        data-swatch
                        data-index="option{{ optidx }}"
                        data-value="{{ value | escape }}"
                        role="radio" aria-checked="{% if selected %}true{% else %}false{% endif %}"
                        aria-label="{{ value | escape }}" title="{{ value | escape }}"></button>
                    {%- endfor -%}
                  </div>
                  <input type="hidden" class="product-option" data-index="option{{ optidx }}" value="{{ option.selected_value | escape }}">
                {%- else -%}
                  <select id="opt-{{ optidx }}" class="product-option" data-index="option{{ optidx }}">
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <select name="id" class="product-variant-id" style="display:none">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }} — {{ variant.price | money }}
              </option>
            {%- endfor -%}
          </select>

          {%- if section.settings.pdp_show_countdown -%}
            <p class="pdp-ship-timer" data-ship-timer data-cutoff="{{ section.settings.pdp_cutoff_hour | default: 12 }}" hidden></p>
          {%- endif -%}

          <div class="pdp-actions">
            <div class="qty" data-qty>
              <button type="button" data-qty-down aria-label="Decrease quantity">−</button>
              <input type="text" name="quantity" value="1" inputmode="numeric" aria-label="Quantity">
              <button type="button" data-qty-up aria-label="Increase quantity">+</button>
            </div>
            <button type="submit" name="add" class="btn lg" data-add-btn style="flex:1" {% unless product.available %}disabled{% endunless %}>
              {%- if product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
            </button>
          </div>
          {%- if product.available -%}
            <div class="pdp-dynamic-checkout" style="margin-top:.7rem">{{ form | payment_button }}</div>
          {%- endif -%}
        {%- endform -%}

        {%- if section.settings.pdp_show_payments -%}
          <div class="pdp-pay">
            <span class="pdp-pay-lbl">🔒 Guaranteed safe &amp; secure checkout</span>
            <div class="pdp-pay-chips">
              <span>Shop&nbsp;Pay</span><span>Apple&nbsp;Pay</span><span>Google&nbsp;Pay</span><span>Visa</span><span>Mastercard</span><span>Amex</span><span>PayPal</span>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.pdp_benefit_1 != blank or section.settings.pdp_benefit_2 != blank or section.settings.pdp_benefit_3 != blank or section.settings.pdp_benefit_4 != blank -%}
          <ul class="pdp-benefits">
            {%- if section.settings.pdp_benefit_1 != blank -%}<li>{{ section.settings.pdp_benefit_1 }}</li>{%- endif -%}
            {%- if section.settings.pdp_benefit_2 != blank -%}<li>{{ section.settings.pdp_benefit_2 }}</li>{%- endif -%}
            {%- if section.settings.pdp_benefit_3 != blank -%}<li>{{ section.settings.pdp_benefit_3 }}</li>{%- endif -%}
            {%- if section.settings.pdp_benefit_4 != blank -%}<li>{{ section.settings.pdp_benefit_4 }}</li>{%- endif -%}
          </ul>
        {%- endif -%}

        <div class="pdp-trust">
          <div><span class="ic">🇺🇸</span><div><b>Handmade in the USA</b><small>Hand-poured in Tampa, FL</small></div></div>
          <div><span class="ic">🚚</span><div><b>Free US shipping</b><small>Fast same-day dispatch</small></div></div>
          <div><span class="ic">↩︎</span><div><b>30-day returns</b><small>Love it or send it back</small></div></div>
          <div><span class="ic">🔒</span><div><b>Secure checkout</b><small>Shop Pay, Apple Pay &amp; cards</small></div></div>
        </div>

        {%- if section.settings.pdp_guarantee_title != blank -%}
          <div class="pdp-guarantee">
            <span class="pdp-guarantee-ic">💛</span>
            <div><b>{{ section.settings.pdp_guarantee_title }}</b>{%- if section.settings.pdp_guarantee_text != blank -%}<p>{{ section.settings.pdp_guarantee_text }}</p>{%- endif -%}</div>
          </div>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="pdp-desc rte">{{ product.description }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .pdp-stock{display:inline-flex;align-items:center;gap:.4rem;background:rgba(220,26,87,.08);color:var(--cta,#DC1A57);font-weight:700;font-size:.9rem;padding:.4rem .75rem;border-radius:999px;margin:.1rem 0 .7rem}
  .pdp-ship-timer{font-size:.92rem;color:var(--ink,#34202C);background:#FFF7E8;border:1px solid #F6DFA0;border-radius:12px;padding:.55rem .8rem;margin:.2rem 0 .9rem}
  .pdp-ship-timer strong{color:#B5134A}
  .pdp-pay{margin:.85rem 0 0;text-align:center}
  .pdp-pay-lbl{display:block;font-size:.82rem;color:var(--ink-soft,#7C6070);margin-bottom:.4rem}
  .pdp-pay-chips{display:flex;flex-wrap:wrap;gap:.35rem;justify-content:center}
  .pdp-pay-chips span{font-size:.7rem;font-weight:700;letter-spacing:.02em;color:var(--ink-soft,#7C6070);background:#fff;border:1px solid var(--line,rgba(0,0,0,.1));border-radius:6px;padding:.25rem .5rem}
  .pdp-benefits{list-style:none;padding:0;margin:1.2rem 0;display:grid;gap:.5rem}
  .pdp-benefits li{position:relative;padding-left:1.7rem;color:var(--ink,#34202C);font-size:.96rem;line-height:1.35}
  .pdp-benefits li::before{content:"✓";position:absolute;left:0;top:.05rem;color:#fff;background:var(--cta,#DC1A57);width:1.15rem;height:1.15rem;border-radius:50%;font-size:.72rem;display:grid;place-items:center;font-weight:800}
  .pdp-trust{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.2rem 0;padding:1rem;background:rgba(255,255,255,.6);border:1px solid var(--line,rgba(0,0,0,.06));border-radius:16px}
  .pdp-trust > div{display:flex;gap:.55rem;align-items:flex-start}
  .pdp-trust .ic{font-size:1.2rem;line-height:1.1;flex:none}
  .pdp-trust b{display:block;font-size:.9rem}
  .pdp-trust small{color:var(--ink-soft,#7C6070);font-size:.78rem}
  .pdp-guarantee{display:flex;gap:.7rem;align-items:center;margin:1.2rem 0;padding:1rem 1.1rem;background:linear-gradient(120deg,rgba(255,206,46,.16),rgba(255,111,176,.13));border-radius:16px}
  .pdp-guarantee-ic{font-size:1.9rem;flex:none}
  .pdp-guarantee b{font-family:var(--font-display,sans-serif);font-size:1.02rem}
  .pdp-guarantee p{margin:.12rem 0 0;font-size:.88rem;color:var(--ink-soft,#7C6070)}
  @media(max-width:520px){ .pdp-trust{grid-template-columns:1fr} }
</style>
<script>
  (function(){
    var form = document.getElementById('pdp-add');
    if(!form) return;
    var hidden = form.querySelector('.product-variant-id');
    var inputs = form.querySelectorAll('.product-option');
    var variants = {{ product.variants | json }};
    var threshold = {{ section.settings.pdp_scarcity_threshold | default: 10 }};
    var showScarcity = {{ section.settings.pdp_show_scarcity | default: true | json }};
    var stockEl = document.querySelector('[data-stock]');
    var stockN = stockEl ? stockEl.querySelector('[data-stock-n]') : null;
    var addBtn = form.querySelector('[data-add-btn]');

    function applyVariant(v){
      if(!v) return;
      hidden.value = v.id;
      if(addBtn){
        if(v.available){ addBtn.disabled = false; if(addBtn.textContent.trim() !== 'Add to cart') addBtn.textContent = 'Add to cart'; }
        else { addBtn.disabled = true; addBtn.textContent = 'Sold out'; }
      }
      if(stockEl){
        var low = showScarcity && v.inventory_management && v.inventory_quantity > 0 && v.inventory_quantity <= threshold;
        if(low){ if(stockN) stockN.textContent = v.inventory_quantity; stockEl.hidden = false; }
        else { stockEl.hidden = true; }
      }
    }
    function update(){
      var chosen = [];
      inputs.forEach(function(s){ chosen.push(s.value); });
      for(var i=0;i<variants.length;i++){
        var v = variants[i], match = true;
        for(var j=0;j<chosen.length;j++){ if(v.options[j] !== chosen[j]) match = false; }
        if(match){ applyVariant(v); return; }
      }
    }
    inputs.forEach(function(s){ if(s.tagName === 'SELECT') s.addEventListener('change', update); });
    form.querySelectorAll('[data-swatch]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var idx = btn.getAttribute('data-index');
        var val = btn.getAttribute('data-value');
        var input = form.querySelector('.product-option[data-index="'+idx+'"]');
        if(input){ input.value = val; }
        form.querySelectorAll('[data-swatch][data-index="'+idx+'"]').forEach(function(s){
          var on = s === btn;
          s.classList.toggle('active', on);
          s.setAttribute('aria-checked', on ? 'true' : 'false');
        });
        var cur = form.querySelector('[data-opt-current="'+idx+'"]');
        if(cur) cur.textContent = val;
        update();
      });
    });
    update();

    var timerEl = document.querySelector('[data-ship-timer]');
    if(timerEl){
      var cutoff = parseInt(timerEl.getAttribute('data-cutoff'), 10); if(isNaN(cutoff)) cutoff = 12;
      var tick = function(){
        var nowET = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }));
        var c = new Date(nowET); c.setHours(cutoff, 0, 0, 0);
        var day = nowET.getDay();
        if(nowET < c && day >= 1 && day <= 5){
          var d = c - nowET, h = Math.floor(d/3600000), m = Math.floor(d%3600000/60000), s = Math.floor(d%60000/1000);
          timerEl.innerHTML = '⏱ Order within <strong>' + h + 'h ' + (m<10?'0':'') + m + 'm ' + (s<10?'0':'') + s + 's</strong> for same-day dispatch';
        } else {
          timerEl.innerHTML = '🚚 Order now — ships the next business day';
        }
        timerEl.hidden = false;
      };
      tick(); setInterval(tick, 1000);
    }
  })();
</script>
{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "header", "content": "Trust & conversion" },
    { "type": "checkbox", "id": "pdp_show_scarcity", "label": "Show low-stock urgency", "default": true },
    { "type": "range", "id": "pdp_scarcity_threshold", "label": "Low-stock threshold", "min": 1, "max": 25, "step": 1, "default": 10 },
    { "type": "checkbox", "id": "pdp_show_countdown", "label": "Show same-day shipping countdown", "default": true },
    { "type": "range", "id": "pdp_cutoff_hour", "label": "Same-day cutoff hour (ET, 24h)", "min": 0, "max": 23, "step": 1, "default": 12 },
    { "type": "checkbox", "id": "pdp_show_payments", "label": "Show payment badges", "default": true },
    { "type": "header", "content": "Benefit ticks" },
    { "type": "text", "id": "pdp_benefit_1", "label": "Benefit 1", "default": "Hand-poured resin — no two alike" },
    { "type": "text", "id": "pdp_benefit_2", "label": "Benefit 2", "default": "Tarnish-proof gold chain" },
    { "type": "text", "id": "pdp_benefit_3", "label": "Benefit 3", "default": "18\" length — lightweight & comfy" },
    { "type": "text", "id": "pdp_benefit_4", "label": "Benefit 4", "default": "Free US shipping, ships fast" },
    { "type": "header", "content": "Guarantee" },
    { "type": "text", "id": "pdp_guarantee_title", "label": "Guarantee title", "default": "30-Day Happiness Guarantee" },
    { "type": "text", "id": "pdp_guarantee_text", "label": "Guarantee text", "default": "Love it or send it back for a full refund — no fuss." }
  ]
}
{% endschema %}
