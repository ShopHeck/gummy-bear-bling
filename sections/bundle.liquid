{%- assign variant_product = section.settings.variant_product -%}
{%- assign bundle_product = section.settings.product -%}
<div class="section" id="bundle">
  <div class="wrap">
    <div class="bundle gummy reveal" data-stack
      data-add-url="{{ routes.cart_add_url }}"
      data-cart-url="{{ routes.cart_url }}">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="font-size:clamp(1.8rem,4vw,2.6rem)">{{ section.settings.heading }}</h2>
        <p class="muted" style="font-weight:500;margin-top:.4rem">{{ section.settings.text }}</p>
        <div class="priceline">
          {%- if variant_product == blank and bundle_product != blank -%}
            <span class="now">{{ bundle_product.price | money }}</span>
            {%- if bundle_product.compare_at_price > bundle_product.price -%}
              <span class="was">{{ bundle_product.compare_at_price | money }}</span>
              <span class="save">Save {{ bundle_product.compare_at_price | minus: bundle_product.price | money }}</span>
            {%- elsif section.settings.save_text != blank -%}
              <span class="was">{{ section.settings.compare }}</span>
              <span class="save">{{ section.settings.save_text }}</span>
            {%- endif -%}
          {%- else -%}
            {%- if section.settings.price != blank -%}<span class="now">{{ section.settings.price }}</span>{%- endif -%}
            {%- if section.settings.compare != blank -%}<span class="was">{{ section.settings.compare }}</span>{%- endif -%}
            {%- if section.settings.save_text != blank -%}<span class="save">{{ section.settings.save_text }}</span>{%- endif -%}
          {%- endif -%}
        </div>
        <div class="pickrow" data-stack-picker>
          {%- if variant_product != blank -%}
            {% render 'flavor-from-variants', product: variant_product, mode: 'stack' %}
          {%- else -%}
            {%- for block in section.blocks -%}
              <button type="button" class="swatch" data-stack-flavor
                style="background:{{ block.settings.color }}"
                data-color="{{ block.settings.color }}"
                data-label="{{ block.settings.label | escape }}"
                aria-label="Add {{ block.settings.label | escape }} to your stack"
                {{ block.shopify_attributes }}></button>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <p class="bundle-hint muted" data-stack-hint>Pick 3 flavors to fill your stack.</p>
        {%- if variant_product != blank -%}
          {%- assign bundle_url = variant_product.url -%}
        {%- else -%}
          {%- assign bundle_url = bundle_product.url | default: section.settings.cta_link | default: routes.all_products_collection_url -%}
        {%- endif -%}
        <a href="{{ bundle_url }}"
           class="btn is-disabled"
           data-stack-cta
           aria-disabled="true"
           {%- if variant_product != blank -%}
             data-variant-mode="true"
           {%- elsif bundle_product != blank and bundle_product.available -%}
             data-variant-id="{{ bundle_product.selected_or_first_available_variant.id }}"
           {%- else -%}
             data-base-url="{{ bundle_url }}"
           {%- endif -%}
           style="margin-top:1.2rem">{{ section.settings.cta_text }}</a>
      </div>
      <div>
        <div class="slots" data-stack-slots>
          {%- for i in (1..3) -%}
            <div class="slot" data-stack-slot>
              <span class="ph-num">{{ i }}</span>
              <span class="bearbox" data-bear data-filled="1"></span>
              <span class="slot-x" aria-hidden="true">×</span>
            </div>
          {%- endfor -%}
        </div>
        <p class="center muted" style="font-size:.82rem;font-weight:600">Tap a slot to clear it · free US shipping</p>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Build a stack",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Build a stack" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three bears, better together" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Layer your favorites and save — way more fun than one. Tap colors below to fill your stack." },
    { "type": "header", "content": "Variant mode (recommended)" },
    { "type": "product", "id": "variant_product", "label": "Necklace product", "info": "Pick one necklace with colour/flavour variants. Each variant becomes a flavor; the chosen 3 are added to cart as real variant line items. Set up a Shopify automatic discount (e.g. buy 3 → $15 off) to apply the bundle saving." },
    { "type": "header", "content": "Fixed-price bundle mode (alternative)" },
    { "type": "product", "id": "product", "label": "Bundle product", "info": "A single fixed-price 3-bear bundle product (assign it the \"Build-a-stack bundle\" template). Used only when no necklace product is set above; picks are saved as line-item properties." },
    { "type": "header", "content": "Price display & fallback" },
    { "type": "text", "id": "price", "label": "Bundle price", "default": "$45" },
    { "type": "text", "id": "compare", "label": "Compare price", "default": "$60" },
    { "type": "text", "id": "save_text", "label": "Save badge", "default": "Save $15" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Add stack to cart" },
    { "type": "url", "id": "cta_link", "label": "Fallback button link" }
  ],
  "blocks": [
    {
      "type": "flavor",
      "name": "Flavor",
      "settings": [
        { "type": "color", "id": "color", "label": "Bear color", "default": "#FF3B5C" },
        { "type": "text", "id": "label", "label": "Flavor name", "default": "Cherry" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Build a stack",
    "blocks": [
      { "type": "flavor", "settings": { "color": "#FF3B5C", "label": "Cherry" } },
      { "type": "flavor", "settings": { "color": "#FF8A3D", "label": "Tangerine" } },
      { "type": "flavor", "settings": { "color": "#FFCE2E", "label": "Lemon" } },
      { "type": "flavor", "settings": { "color": "#46CF7C", "label": "Lime" } },
      { "type": "flavor", "settings": { "color": "#3D8BFF", "label": "Blueberry" } },
      { "type": "flavor", "settings": { "color": "#A55CFF", "label": "Grape" } },
      { "type": "flavor", "settings": { "color": "#FF6FB0", "label": "Bubblegum" } },
      { "type": "flavor", "settings": { "color": "#34D6D6", "label": "Aqua" } }
    ]
  }]
}
{% endschema %}
