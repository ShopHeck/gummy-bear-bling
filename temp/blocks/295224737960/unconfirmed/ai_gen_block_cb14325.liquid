      "default": "Find answers to common questions about our jewelry"
    },
    {
      "type": "header",
      "content": "Question 1"
    },
    {
      "type": "text",
      "id": "question_1",
      "label": "Question",
      "default": "What materials are your gummy bear jewelry made from?"
    },
    {
      "type": "textarea",
      "id": "answer_1",
      "label": "Answer",
      "default": "Our gummy bear jewelry is crafted from high-quality materials including 14k gold, sterling silver, and genuine gemstones. Each piece is carefully designed to capture the playful spirit of gummy bears while maintaining luxury quality."
    },
    {
      "type": "header",
      "content": "Question 2"
    },
